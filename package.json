{
  "name": "@skinpricer/sdk",
  "version": "0.2.0",
  "description": "Official, fully-typed TypeScript SDK for the Skinpricer pricing API (CS2 skin market pricing data).",
  "license": "MIT",
  "author": "Skinpricer",
  "homepage": "https://skinpricer.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Skinpricer/sdk.git"
  },
  "bugs": {
    "url": "https://github.com/Skinpricer/sdk/issues"
  },
  "keywords": [
    "skinpricer",
    "cs2",
    "csgo",
    "skins",
    "pricing",
    "api",
    "sdk",
    "nbbo",
    "marketplace"
  ],
  "type": "module",
  "engines": {
    "node": ">=18.17"
  },
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,mjs,json,md}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:types": "vitest --typecheck run",
    "check:package": "publint && attw --pack .",
    "prepublishOnly": "pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm check:package",
    "release": "changeset publish"
  },
  "dependencies": {},
  "peerDependencies": {},
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@changesets/cli": "^2.27.9",
    "@eslint/js": "^9.13.0",
    "@types/node": "^20.16.0",
    "@vitest/coverage-v8": "^2.1.3",
    "eslint": "^9.13.0",
    "prettier": "^3.3.3",
    "publint": "^0.3.2",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.10.0",
    "vitest": "^2.1.3"
  },
  "packageManager": "pnpm@10.15.1"
}
